<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focusdesk.controller.MainController"
      prefWidth="1140" prefHeight="720"
      style="-fx-background-color: linear-gradient(to bottom right, #181a1f, #111217);">

    <left>
  <VBox prefWidth="230" spacing="10" style="-fx-background-color: #1f2229; -fx-border-color: #2a2f3a; -fx-border-width: 0 1 0 0;">
      <padding>
    <Insets top="18" right="14" bottom="18" left="14"/>
      </padding>

      <Label text="FocusDesk" style="-fx-text-fill: #f3f6ff; -fx-font-size: 22; -fx-font-weight: bold;"/>
      <Label fx:id="welcomeLabel" text="Welcome" style="-fx-text-fill: #93a0ba; -fx-font-size: 12;"/>

      <Region prefHeight="10"/>

      <Button text="Overview" onAction="#showOverview" maxWidth="Infinity"
        style="-fx-background-color: #2b65d9; -fx-text-fill: #f8fbff; -fx-background-radius: 10; -fx-font-weight: bold;"/>
      <Button text="Tasks" onAction="#showTodo" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>
      <Button text="Pomodoro" onAction="#showTimer" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>
      <Button text="Calendar" onAction="#showCalendar" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>
      <Button text="Music" onAction="#showMusic" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>
      <Button text="Notes" onAction="#showNotes" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>

      <Region VBox.vgrow="ALWAYS"/>

      <Button fx:id="widgetToggleButton" text="Open Widget" onAction="#toggleWidget" maxWidth="Infinity"
        style="-fx-background-color: #121418; -fx-text-fill: #7ec8ff; -fx-border-color: #2f8be7; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold;"/>
      <Button text="Logout" onAction="#onLogout" maxWidth="Infinity"
        style="-fx-background-color: #2a2f3a; -fx-text-fill: #dce3f5; -fx-background-radius: 10;"/>
  </VBox>
    </left>

    <center>
  <VBox spacing="14" style="-fx-background-color: transparent;">
      <padding>
    <Insets top="18" right="18" bottom="18" left="18"/>
      </padding>

      <HBox alignment="CENTER_LEFT" spacing="8">
    <Label fx:id="sectionTitleLabel" text="Dashboard"
           style="-fx-text-fill: #f4f7ff; -fx-font-size: 30; -fx-font-weight: bold;"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Label fx:id="sectionHintLabel" text="Today at a glance"
           style="-fx-text-fill: #8f9bb3; -fx-font-size: 12;"/>
      </HBox>

      <StackPane fx:id="mainContentHost" VBox.vgrow="ALWAYS"
           style="-fx-background-color: #20242e; -fx-border-color: #313846; -fx-border-radius: 14; -fx-background-radius: 14; -fx-padding: 16;"/>
  </VBox>
    </center>
</BorderPane>
