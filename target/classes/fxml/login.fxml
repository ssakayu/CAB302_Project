<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
       xmlns:fx="http://javafx.com/fxml"
       fx:controller="com.focusdesk.controller.LoginController"
       style="-fx-background-color: #161616;">

    <VBox alignment="TOP_CENTER" spacing="16" maxWidth="460"
          style="-fx-background-color: #2d2d2d; -fx-padding: 34 34 28 34; -fx-background-radius: 12; -fx-border-color: #575757; -fx-border-radius: 12;">

        <VBox alignment="CENTER" spacing="10">
                    <StackPane prefWidth="56" prefHeight="56" maxWidth="56" maxHeight="56"
                 style="-fx-background-color: #ebf2ff; -fx-background-radius: 16;">
            <Label text="▣" style="-fx-text-fill: #6d8cff; -fx-font-size: 24; -fx-font-weight: bold;"/>
          </StackPane>
          <Label text="FocusDesk" style="-fx-text-fill: #f7f7f7; -fx-font-size: 26; -fx-font-weight: bold;"/>
          <Label text="Your study workspace, always within reach."
               style="-fx-text-fill: #ddd1b3; -fx-font-size: 14;"/>
        </VBox>

        <HBox alignment="CENTER" spacing="0" maxWidth="Infinity">
          <Button text="Log in" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onLogin"
              style="-fx-background-color: transparent; -fx-text-fill: #5aa4ff; -fx-font-size: 16; -fx-font-weight: bold; -fx-border-color: transparent transparent #4ca0ff transparent; -fx-border-width: 0 0 2 0; -fx-background-radius: 0;"/>
          <Button text="Sign up" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onGoSignup"
              style="-fx-background-color: transparent; -fx-text-fill: #e0d0a7; -fx-font-size: 16; -fx-font-weight: bold; -fx-border-color: transparent transparent #5a5a5a transparent; -fx-border-width: 0 0 2 0; -fx-background-radius: 0;"/>
        </HBox>

        <VBox spacing="8" maxWidth="Infinity">
          <Label text="Username or email" style="-fx-text-fill: #f2e5bf; -fx-font-size: 13; -fx-font-weight: bold;"/>
          <TextField fx:id="emailField" promptText="Enter your username or email"
                 style="-fx-background-color: #3a3a3a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #8e8e8e; -fx-background-radius: 8; -fx-border-color: #5a5a5a; -fx-border-radius: 8; -fx-padding: 10 12 10 12;"/>
        </VBox>

        <VBox spacing="8" maxWidth="Infinity">
          <Label text="Password" style="-fx-text-fill: #f2e5bf; -fx-font-size: 13; -fx-font-weight: bold;"/>
          <PasswordField fx:id="passwordField" promptText="Enter your password"
                   style="-fx-background-color: #3a3a3a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #8e8e8e; -fx-background-radius: 8; -fx-border-color: #5a5a5a; -fx-border-radius: 8; -fx-padding: 10 12 10 12;"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
          <Label text="Forgot password?" style="-fx-text-fill: #4ca0ff; -fx-font-size: 12;"/>
        </HBox>

        <Button text="Log in" onAction="#onLogin" maxWidth="Infinity"
            style="-fx-background-color: #3d3d3d; -fx-text-fill: #ffffff; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #5a5a5a; -fx-border-radius: 8; -fx-padding: 10 0 10 0;"/>

        <HBox alignment="CENTER" spacing="12">
          <Region HBox.hgrow="ALWAYS" style="-fx-pref-height: 1; -fx-background-color: #5c5c5c;"/>
          <Label text="don't have an account?" style="-fx-text-fill: #d8cfb0; -fx-font-size: 12;"/>
          <Region HBox.hgrow="ALWAYS" style="-fx-pref-height: 1; -fx-background-color: #5c5c5c;"/>
        </HBox>

        <Button text="Create account" onAction="#onGoSignup" maxWidth="Infinity"
            style="-fx-background-color: #3d3d3d; -fx-text-fill: #ffffff; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #5a5a5a; -fx-border-radius: 8; -fx-padding: 10 0 10 0;"/>

        <Label fx:id="messageLabel" wrapText="true" style="-fx-text-fill: #ff6a6a; -fx-font-size: 12;"/>
  </VBox>
</StackPane>
