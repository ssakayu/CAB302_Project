<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focusdesk.controller.widget.TimerSettingsController"
      spacing="16"
      style="-fx-padding: 20; -fx-background-color: #1b1f27;">

    <Label text="Pomodoro Settings"
           style="-fx-text-fill: #f0f4ff; -fx-font-size: 16; -fx-font-weight: bold;"/>

    <!-- Focus Duration -->
    <VBox spacing="6">
        <HBox spacing="8">
            <Label text="Focus Duration:" style="-fx-text-fill: #8ca4cc; -fx-font-size: 12;"/>
            <Label fx:id="focusValueLabel" text="25 min" style="-fx-text-fill: #f0f4ff; -fx-font-size: 12;"/>
        </HBox>
        <Slider fx:id="focusSlider" min="15" max="60" value="25"
                style="-fx-padding: 0;"/>
    </VBox>

    <!-- Short Break Duration -->
    <VBox spacing="6">
        <HBox spacing="8">
            <Label text="Short Break:" style="-fx-text-fill: #8ca4cc; -fx-font-size: 12;"/>
            <Label fx:id="breakValueLabel" text="5 min" style="-fx-text-fill: #f0f4ff; -fx-font-size: 12;"/>
        </HBox>
        <Slider fx:id="breakSlider" min="1" max="15" value="5"
                style="-fx-padding: 0;"/>
    </VBox>

    <!-- Long Break Duration -->
    <VBox spacing="6">
        <HBox spacing="8">
            <Label text="Long Break:" style="-fx-text-fill: #8ca4cc; -fx-font-size: 12;"/>
            <Label fx:id="longBreakValueLabel" text="15 min" style="-fx-text-fill: #f0f4ff; -fx-font-size: 12;"/>
        </HBox>
        <Slider fx:id="longBreakSlider" min="10" max="30" value="15"
                style="-fx-padding: 0;"/>
    </VBox>

    <!-- Cycles Before Long Break -->
    <VBox spacing="6">
        <HBox spacing="8">
            <Label text="Cycles Before Long Break:" style="-fx-text-fill: #8ca4cc; -fx-font-size: 12;"/>
            <Label fx:id="cyclesValueLabel" text="4" style="-fx-text-fill: #f0f4ff; -fx-font-size: 12;"/>
        </HBox>
        <Slider fx:id="cyclesSlider" min="1" max="6" value="4"
                style="-fx-padding: 0;"/>
    </VBox>

    <!-- Sound Notifications -->
    <CheckBox fx:id="soundCheckbox" text="Enable sound notifications"
              style="-fx-text-fill: #8ca4cc; -fx-font-size: 12;" selected="true"/>

    <!-- Separator -->
    <Label style="-fx-border-color: #2f3443; -fx-border-width: 1 0 0 0;"/>

    <!-- Save & Cancel Buttons -->
    <HBox spacing="8" style="-fx-alignment: center-right;">
        <Button text="Cancel"
                style="-fx-padding: 8 16 8 16; -fx-font-size: 12; -fx-background-color: #5a4a5a; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onCancel"/>
        <Button text="Save"
                style="-fx-padding: 8 16 8 16; -fx-font-size: 12; -fx-background-color: #4a7c8c; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onSave"/>
    </HBox>

</VBox>
