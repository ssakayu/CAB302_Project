<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focusdesk.controller.widget.TimerSlideController"
      spacing="8"
      style="-fx-padding: 10; -fx-background-color: #262c36; -fx-background-radius: 10; -fx-alignment: center;">

    <Label fx:id="phaseLabel" text="Focus ??"
           style="-fx-text-fill: #8ca4cc; -fx-font-size: 12; -fx-font-weight: bold; -fx-alignment: center;"/>

    <Label fx:id="sessionLabel" text="Session 1 of 4"
           style="-fx-text-fill: #f0f4ff; -fx-font-size: 11; -fx-alignment: center;"/>

    <StackPane fx:id="timerContainer"
               VBox.vgrow="ALWAYS"
               style="-fx-alignment: center;">
        <Label fx:id="timeLabel" text="25:00"
               style="-fx-text-fill: #f0f4ff; -fx-font-size: 36; -fx-font-weight: bold; -fx-text-alignment: center;"/>
    </StackPane>

    <HBox spacing="6" style="-fx-alignment: center;">
        <Button fx:id="startPauseBtn" text="Start"
                style="-fx-padding: 6 12 6 12; -fx-font-size: 11; -fx-background-color: #4a7c8c; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onStartPause"/>
        <Button fx:id="resetBtn" text="Reset"
                style="-fx-padding: 6 12 6 12; -fx-font-size: 11; -fx-background-color: #5a4a5a; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onReset"/>
        <Button fx:id="skipBtn" text="Skip"
                style="-fx-padding: 6 12 6 12; -fx-font-size: 11; -fx-background-color: #5a5a4a; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onSkip"/>
        <Button fx:id="settingsBtn" text="?"
                style="-fx-padding: 6 10 6 10; -fx-font-size: 12; -fx-background-color: #444; -fx-text-fill: white; -fx-background-radius: 4;"
                onAction="#onSettings"/>
    </HBox>

</VBox>
