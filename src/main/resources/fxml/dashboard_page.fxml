<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12"
      styleClass="dashboard-page">

    <padding>
        <Insets top="10" right="12" bottom="10" left="12"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Dashboard" styleClass="dashboard-title"/>
        <Label text="Study flow: 25 focus / 5 break / 4 sessions" styleClass="dashboard-subtitle"/>
    </HBox>

    <GridPane hgap="10" vgap="10" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints percentHeight="50"/>
            <RowConstraints percentHeight="50"/>
        </rowConstraints>

        <VBox styleClass="dashboard-card" GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.vgrow="ALWAYS" maxHeight="Infinity">
            <Label text="Pomodoro Timer" styleClass="dashboard-card-title"/>
            <fx:include source="timer_dashboard.fxml"/>
        </VBox>

        <VBox styleClass="dashboard-card" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS" maxHeight="Infinity">
            <Label text="Today" styleClass="dashboard-card-title"/>
            <Label text="Open Calendar to manage schedule blocks." styleClass="dashboard-card-text"/>
            <Label text="Open Tasks to choose your active task before each focus session." styleClass="dashboard-card-text"/>
        </VBox>

        <VBox styleClass="dashboard-card" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.vgrow="ALWAYS" maxHeight="Infinity">
            <Label text="Tasks" styleClass="dashboard-card-title"/>
            <Label text="Connect this with your task list to pick a task before each session." styleClass="dashboard-card-text" wrapText="true"/>
        </VBox>

        <VBox styleClass="dashboard-card" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS" maxHeight="Infinity">
            <Label text="Notes" styleClass="dashboard-card-title"/>
            <Label text="Keep quick notes while studying and review after each cycle." styleClass="dashboard-card-text" wrapText="true"/>
        </VBox>
    </GridPane>
</VBox>
