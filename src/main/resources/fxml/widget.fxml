<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focusdesk.controller.widget.WidgetController"
            styleClass="widget-root"
            stylesheets="@../css/widget.css"
            prefWidth="380" prefHeight="220">

    <!-- Header — used as drag handle -->
    <top>
        <HBox fx:id="header" styleClass="widget-header" alignment="CENTER_LEFT">
            <Label fx:id="slideTitle" text="To-Do" styleClass="widget-title" HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="widget-close-btn" onAction="#onClose"/>
        </HBox>
    </top>

    <!-- Slides stacked on top of each other; only one visible at a time -->
    <center>
        <StackPane fx:id="slideContainer" styleClass="slide-container">

            <fx:include source="todo_slide.fxml"/>

            <!-- Slide 1: Pomodoro Timer -->
            <VBox spacing="4" alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity">
                <Label text="FOCUS" styleClass="timer-label"/>
                <Label text="25:00" styleClass="timer-display"/>
                <Label text="Session 1 of 4" styleClass="timer-label"/>
            </VBox>

            <!-- Slide 2: Notes — quick-write; view in main window -->
            <VBox spacing="8" maxWidth="Infinity" maxHeight="Infinity"
                  StackPane.alignment="TOP_LEFT">
                <TextArea fx:id="quickNoteInput"
                          promptText="Write a quick note..."
                          styleClass="widget-note-input"
                          wrapText="true"
                          VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Label fx:id="noteSavedLabel" text="✓ Saved"
                           styleClass="note-saved-label"
                           visible="false" managed="false"/>
                    <Button text="Save" styleClass="widget-quick-save-btn"
                            onAction="#onQuickNoteSave"/>
                </HBox>
            </VBox>

            <!-- Slide 3: Calendar -->
            <VBox spacing="8" maxWidth="Infinity" maxHeight="Infinity" StackPane.alignment="TOP_LEFT">
                <Label text="Mon, 28 Apr 2025" styleClass="calendar-date"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Region styleClass="event-dot event-dot-blue"/>
                    <Label text="9:00 AM  Team standup" styleClass="event-label"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Region styleClass="event-dot event-dot-green"/>
                    <Label text="2:00 PM  Code review" styleClass="event-label"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Region styleClass="event-dot event-dot-orange"/>
                    <Label text="4:00 PM  Sprint planning" styleClass="event-label"/>
                </HBox>
            </VBox>

            <!-- Slide 4: Music -->
            <VBox spacing="4" alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity">
                <Label text="♪" styleClass="music-note"/>
                <Label text="NOW PLAYING" styleClass="timer-label"/>
                <Label text="Lofi Hip Hop Radio" styleClass="music-title"/>
                <Label text="ChilledCow" styleClass="timer-label"/>
            </VBox>

        </StackPane>
    </center>

    <!-- Navigation bar + resize handle -->
    <bottom>
        <HBox fx:id="navBar" styleClass="widget-nav" alignment="CENTER" spacing="6">
            <Button fx:id="prevBtn" text="‹" styleClass="nav-arrow" onAction="#onPrev"/>
            <HBox fx:id="dotsContainer" spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS"/>
            <Button fx:id="nextBtn" text="›" styleClass="nav-arrow" onAction="#onNext"/>
            <!-- SE corner drag-to-resize handle -->
            <Region fx:id="resizeHandle" styleClass="resize-handle" prefWidth="14" prefHeight="14"/>
        </HBox>
    </bottom>

</BorderPane>
