<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focusdesk.controller.widget.WidgetController"
            prefWidth="430" prefHeight="260"
            style="-fx-background-color: #1b1f27; -fx-background-radius: 18; -fx-background-insets: 0; -fx-border-color: #2f3443; -fx-border-radius: 18; -fx-border-insets: 0; -fx-border-width: 1;">

    <top>
        <HBox fx:id="headerBar" alignment="CENTER_LEFT" spacing="8"
              onMousePressed="#startDrag" onMouseDragged="#dragWidget"
              style="-fx-background-color: #171b22; -fx-background-radius: 18 18 0 0; -fx-padding: 8 10 8 10;">
            <Label text="FocusDesk Widget" style="-fx-text-fill: #f0f4ff; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="slideTitleLabel" text="Pomodoro" style="-fx-text-fill: #8ca4cc; -fx-font-size: 11;"/>
            <Label fx:id="slideCounterLabel" text="1 / 4" style="-fx-text-fill: #8ca4cc; -fx-font-size: 11;"/>
            <Button text="_" onAction="#minimizeToMain"
                    style="-fx-background-color: transparent; -fx-text-fill: #b8c7e6; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 0 6 0 6; -fx-translate-y: -6;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="8" style="-fx-padding: 10;">
            <StackPane fx:id="slideHost" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #242a36; -fx-background-radius: 14; -fx-padding: 8;"/>
            <HBox alignment="CENTER" spacing="10">
                <Button text="◀" onAction="#showPreviousSlide"
                        style="-fx-background-color: #2c3442; -fx-text-fill: #e5ebff; -fx-background-radius: 20; -fx-min-width: 36; -fx-min-height: 36;"/>
                <Button text="▶" onAction="#showNextSlide"
                        style="-fx-background-color: #2c3442; -fx-text-fill: #e5ebff; -fx-background-radius: 20; -fx-min-width: 36; -fx-min-height: 36;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
